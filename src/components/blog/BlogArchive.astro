---
import type { CollectionEntry } from 'astro:content';
import BlogArchiveHeader from './BlogArchiveHeader.astro';
import BlogPostList from './BlogPostList.astro';
import { getSiteConfig } from '../../data/site';
import { getUiText } from '../../utils/ui-text';
import { getPaginationItems } from '../../utils/pagination';

type BlogPost = CollectionEntry<'blog'>;
type CoverImageStyle = 'card' | 'mask';

interface PaginationState {
  currentPage: number;
  lastPage: number;
  total: number;
  size: number;
  url: {
    current: string;
    prev?: string;
    next?: string;
  };
}

interface Props {
  page: PaginationState & {
    data: BlogPost[];
  };
  postOffset?: number;
  headerKicker?: string;
  headerTitle?: string;
  headerSubtitle?: string;
  headerNote?: string;
  coverImageStyle?: CoverImageStyle;
}

const {
  page,
  postOffset = 0,
  headerKicker = 'Notebook archive',
  headerTitle = 'Writing notes',
  headerSubtitle,
  headerNote,
  coverImageStyle = 'card',
} = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const hasPagination = page.lastPage > 1;
const ui = getUiText(await getSiteConfig());

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function getPageHref(pageNumber: number) {
  return pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`;
}
---

<BlogArchiveHeader
  kicker={headerKicker}
  title={headerTitle}
  subtitle={headerSubtitle}
  note={headerNote}
/>
<slot name="after-header" />
<section>
  <BlogPostList posts={page.data} postOffset={postOffset} coverImageStyle={coverImageStyle} />
</section>
{
  hasPagination && (
    <nav class="archive-pagination" aria-label={ui.pagination.blog}>
      <a
        class:list={['pagination-link', { disabled: !page.url.prev }]}
        href={page.url.prev ? withBase(page.url.prev) : undefined}
        aria-disabled={!page.url.prev}
      >
        {ui.pagination.previous}
      </a>
      <div
        class="pagination-pages"
        aria-label={ui.pagination.page(page.currentPage, page.lastPage)}
      >
        {getPaginationItems(page.currentPage, page.lastPage).map((item) => {
          if (item === 'ellipsis') {
            return (
              <span class="pagination-ellipsis" aria-hidden="true">
                …
              </span>
            );
          }

          const pageNumber = item;
          const isCurrent = pageNumber === page.currentPage;

          return (
            <a
              class:list={['pagination-number', { current: isCurrent }]}
              href={withBase(getPageHref(pageNumber))}
              aria-current={isCurrent ? 'page' : undefined}
            >
              {pageNumber}
            </a>
          );
        })}
      </div>
      <a
        class:list={['pagination-link', { disabled: !page.url.next }]}
        href={page.url.next ? withBase(page.url.next) : undefined}
        aria-disabled={!page.url.next}
      >
        {ui.pagination.next}
      </a>
    </nav>
  )
}

<style>
  .archive-pagination {
    display: grid;
    grid-template-columns: minmax(98px, auto) minmax(0, 1fr) minmax(98px, auto);
    gap: 16px;
    align-items: center;
    margin-top: 34px;
    padding-top: 20px;
    border-top: 1px solid var(--paper-line);
    font-family: var(--font-meta);
    font-size: 0.82rem;
  }

  .pagination-pages {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .pagination-link,
  .pagination-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    background: var(--paper-control);
    color: var(--paper-ink-soft);
    text-decoration: none;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .pagination-link {
    padding: 0 14px;
  }

  .pagination-number {
    min-width: 36px;
    padding: 0 10px;
  }

  .pagination-ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    min-height: 36px;
    color: var(--paper-ink-faint);
    user-select: none;
  }

  .pagination-link:hover,
  .pagination-number:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-ink);
    transform: translateY(-1px);
  }

  .pagination-number.current {
    border-color: var(--paper-line-strong);
    background: var(--paper-surface);
    color: var(--paper-accent);
  }

  .pagination-link.disabled {
    pointer-events: none;
    opacity: 0.45;
  }

  @media (max-width: 720px) {
    .archive-pagination {
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 28px;
    }

    .pagination-link,
    .pagination-pages {
      width: 100%;
    }
  }
</style>
