---
import TocTree from './TocTree.astro';
import { getSiteConfig } from '../../data/site';
import { countTocItems, type TocItem } from '../../utils/toc-tree';
import { getUiText } from '../../utils/ui-text';

interface Props {
  items: TocItem[];
  compact?: boolean;
  collapsible?: boolean;
  font?: 'ui' | 'article';
}

const { items, compact = false, collapsible = false, font = 'ui' } = Astro.props;

const hasItems = items.length > 0;
const canCollapse = collapsible && countTocItems(items) > 3;
const listId = collapsible ? 'mobile-article-toc-list' : undefined;
const treeIdPrefix = collapsible ? 'article-toc' : 'sidebar-toc';
const ui = getUiText(await getSiteConfig());
---

{
  hasItems && (
    <nav
      class:list={['toc-card', 'blog-card', { compact, collapsible, 'can-collapse': canCollapse }]}
      aria-label={ui.toc.title}
      data-toc-root
      data-font={font}
      data-mobile-toc={collapsible ? '' : undefined}
      data-expanded={collapsible ? 'false' : undefined}
      data-expand-aria-label={ui.toc.expand}
      data-collapse-aria-label={ui.toc.collapse}
      data-expand-label={ui.toc.showAll}
      data-collapse-label={ui.toc.collapseButton}
    >
      <h2>{ui.toc.title}</h2>
      <div id={listId} class="toc-list-wrap" data-toc-scroll>
        <TocTree items={items} idPrefix={treeIdPrefix} />
      </div>
      {canCollapse && (
        <button
          class="toc-expand"
          type="button"
          aria-label={ui.toc.expand}
          aria-expanded="false"
          aria-controls={listId}
          data-toc-expand
        >
          <span data-expand-label>{ui.toc.showAll}</span>
          <i aria-hidden="true" />
        </button>
      )}
    </nav>
  )
}

<script>
  import { mountNavfolioTocSpy } from '../../utils/toc-spy';

  mountNavfolioTocSpy();

  const initMobileTocToggle = () => {
    for (const toc of document.querySelectorAll<HTMLElement>('[data-mobile-toc]')) {
      const button = toc.querySelector<HTMLButtonElement>(':scope > [data-toc-expand]');
      const label = toc.querySelector<HTMLElement>('[data-expand-label]');

      if (!button || button.dataset.tocExpandReady) {
        continue;
      }

      button.dataset.tocExpandReady = 'true';
      button.addEventListener('click', () => {
        const expanded = toc.dataset.expanded === 'true';
        const nextExpanded = !expanded;

        toc.dataset.expanded = String(nextExpanded);
        button.setAttribute('aria-expanded', String(nextExpanded));
        button.setAttribute(
          'aria-label',
          nextExpanded
            ? (toc.dataset.collapseAriaLabel ?? 'Collapse table of contents')
            : (toc.dataset.expandAriaLabel ?? 'Expand table of contents'),
        );
        if (label) {
          label.textContent = nextExpanded
            ? (toc.dataset.collapseLabel ?? 'Collapse')
            : (toc.dataset.expandLabel ?? 'Show all');
        }
      });
    }
  };

  initMobileTocToggle();
  document.addEventListener('astro:page-load', initMobileTocToggle);
</script>

<style>
  .toc-card {
    padding: 18px;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--paper-ink);
    font-family: var(--font-ui-label);
    font-size: 0.9rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .compact {
    padding: 18px;
  }

  .toc-expand {
    display: none;
  }

  @media (max-width: 900px) {
    .collapsible {
      padding: 16px;
      border: 1px solid var(--paper-line);
      background: var(--paper-surface);
      box-shadow: var(--paper-shadow);
      scroll-margin-top: 78px;
    }

    .can-collapse .toc-expand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      justify-content: center;
      width: 100%;
      margin-top: 10px;
      padding: 8px 10px;
      border: 1px solid var(--paper-line);
      border-radius: 7px;
      background: var(--paper-control);
      color: var(--paper-ink-soft);
      font-family: var(--font-ui-label);
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
      transition:
        background-color 160ms ease,
        color 160ms ease;
    }

    .can-collapse .toc-expand:hover {
      background: var(--paper-control-hover);
      color: var(--paper-accent);
    }

    .toc-expand i {
      width: 7px;
      height: 7px;
      border-right: 1.5px solid currentColor;
      border-bottom: 1.5px solid currentColor;
      transform: translateY(-2px) rotate(45deg);
      transition: transform 160ms ease;
    }

    .can-collapse[data-expanded='true'] .toc-expand i {
      transform: translateY(2px) rotate(225deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toc-expand i {
      transition: none;
    }
  }
</style>
