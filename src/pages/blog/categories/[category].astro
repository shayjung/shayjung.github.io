---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import BlogArchive from '../../../components/blog/BlogArchive.astro';
import BlogTopNav from '../../../components/blog/BlogTopNav.astro';
import GroupNav from '../../../components/blog/GroupNav.astro';
import { getSiteConfig } from '../../../data/site';
import {
  getAllCategories,
  getPostsByCategory,
  uncategorizedCategory,
} from '../../../utils/content-groups';
import { sortBlogPostsForArchive } from '../../../utils/content-dates';
import { getUiText } from '../../../utils/ui-text';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return getAllCategories(posts).map((category) => {
    const categoryPosts = sortBlogPostsForArchive(getPostsByCategory(posts, category.slug));

    return {
      params: { category: category.slug },
      props: {
        category,
        page: {
          data: categoryPosts,
          currentPage: 1,
          lastPage: 1,
          total: categoryPosts.length,
          size: categoryPosts.length,
          url: {
            current: `/blog/categories/${category.slug}/`,
          },
        },
      },
    };
  });
}

const siteConfig = await getSiteConfig();
const { site, theme, pages } = siteConfig;
const palette = theme.palette;
const pageMeta = pages.blog;
const { category, page } = Astro.props;
const ui = getUiText(siteConfig);
const categoryName =
  category.slug === uncategorizedCategory.slug ? ui.groups.uncategorized : category.name;
---

<!doctype html>
<html lang={ui.locale} data-palette={palette}>
  <head>
    <BaseHead title={`${categoryName} | ${site.title}`} description={site.description} />
    <style>
      main {
        width: min(100%, var(--layout-shell-width));
        max-width: none;
        padding: 118px var(--layout-page-gutter) var(--layout-page-bottom);
      }

      @media (max-width: 720px) {
        main {
          padding-top: 88px;
        }
      }
    </style>
  </head>
  <body>
    <BlogTopNav />
    <main data-pagefind-body>
      <BlogArchive
        page={page}
        headerKicker={pageMeta.kicker}
        headerTitle={pageMeta.title}
        headerSubtitle={pageMeta.subtitle}
        headerNote={pageMeta.note}
        coverImageStyle={pageMeta.coverImageStyle}
      >
        <GroupNav slot="after-header" activeCategory={category.slug} />
      </BlogArchive>
    </main>
    <Footer />
  </body>
</html>
